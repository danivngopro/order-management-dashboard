{
  "name": "order-management-dashboard",
  "version": "1.0.0",
  "type": "module",
  "description": "Procurement order management system",
  "scripts": {
    "dev": "node --loader ts-node/esm src/backend/server.ts",
    "build": "tsc",
    "start": "node dist/backend/server.js",
    "seed": "node --loader ts-node/esm src/backend/db/seed.ts",
    "dev:frontend": "cd src/frontend && npm run dev",
    "build:frontend": "cd src/frontend && npm run build",
    "preview:frontend": "cd src/frontend && npm run preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "csv-parse": "^5.5.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.5",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
